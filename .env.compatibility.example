# Copy this file to .env.compatibility and fill in your local MoviePilot backend.
# Read-only checks log in and probe TV-facing API/image surfaces.
# BackendCompatibilitySideEffectTests are enabled by default; disable switches below when needed.
# In another worktree, set MOVIEPILOT_COMPAT_ENV_FILE to this file's absolute path.
MOVIEPILOT_COMPAT_BASE_URL=http://127.0.0.1:3000
MOVIEPILOT_COMPAT_USERNAME=admin
MOVIEPILOT_COMPAT_PASSWORD=your-password

# Optional: run the same compatibility tests with additional accounts. Fill
# both usernames and passwords with your own test users; omit passwords only
# when those accounts intentionally share MOVIEPILOT_COMPAT_PASSWORD. Escape a
# comma inside one password as \, so it is not treated as the next separator.
# MOVIEPILOT_COMPAT_ADDITIONAL_USERNAMES=ordinary-user-1,ordinary-user-2
# MOVIEPILOT_COMPAT_ADDITIONAL_PASSWORDS=ordinary-user-1-password,ordinary-user-2-pa\,ssword

# Optional: dedicated permission-behavior accounts. These accounts only run
# BackendCompatibilityPermissionBehaviorTests and are excluded from the normal
# read-only/side-effect compatibility matrix, even if their usernames also
# appear in MOVIEPILOT_COMPAT_ADDITIONAL_USERNAMES.
# MOVIEPILOT_COMPAT_PERMISSION_BEHAVIOR_ACCOUNTS=test_discovery=discovery,test_search=search,test_subscribe=subscribe,test_manage=manage
# MOVIEPILOT_COMPAT_PERMISSION_PASSWORDS=discovery-password,search-password,subscribe-password,manage-password

# Optional: limit the latest-media check to a specific enabled media server.
# MOVIEPILOT_COMPAT_MEDIA_SERVER=Emby

# Optional: make empty local setup fail instead of skip.
MOVIEPILOT_COMPAT_REQUIRE_MEDIA_SERVER=false
MOVIEPILOT_COMPAT_REQUIRE_LATEST_MEDIA=false

# Optional: extra metadata search/detail read-only checks.
# MOVIEPILOT_COMPAT_METADATA_QUERY=流浪地球
# MOVIEPILOT_COMPAT_METADATA_QUERIES=流浪地球,三体
# MOVIEPILOT_COMPAT_COLLECTION_ID=1241
# MOVIEPILOT_COMPAT_COLLECTION_IDS=1241,87359

# Optional: read-only title recognition samples. Defaults to one common sample.
# MOVIEPILOT_COMPAT_RECOGNITION_TITLE=流浪地球.2023.2160p.WEB-DL.x265
# MOVIEPILOT_COMPAT_RECOGNITION_TITLES=流浪地球.2023.2160p.WEB-DL.x265,三体.S01E01.2160p.WEB-DL

# Optional: resource-search compatibility checks. These only search and decode
# results; they never add downloads or subscriptions. Leave unset to skip.
# MOVIEPILOT_COMPAT_RESOURCE_QUERY=流浪地球
# MOVIEPILOT_COMPAT_RESOURCE_QUERIES=流浪地球,三体
# MOVIEPILOT_COMPAT_RESOURCE_MEDIA_ID=tmdb:12345
# MOVIEPILOT_COMPAT_RESOURCE_MEDIA_IDS=tmdb:12345,douban:1234567
# MOVIEPILOT_COMPAT_RESOURCE_SITES=1,2
MOVIEPILOT_COMPAT_REQUIRE_RESOURCE_RESULTS=false
# Optional: also probe resource-search SSE streams for configured resource queries.
MOVIEPILOT_COMPAT_TEST_RESOURCE_SEARCH_STREAMS=false

# Optional: read-only media-server season availability status check.
# Requires a configured media server; it does not subscribe or download.
MOVIEPILOT_COMPAT_CHECK_SEASON_AVAILABILITY=false

# Side-effect checks run against real data and can trigger subscription searches
# or backend reorganize tasks. They are enabled by default; set any switch to
# false to disable it for a compatibility run.
MOVIEPILOT_COMPAT_ENABLE_SIDE_EFFECTS=true

# Trigger manual search on recent existing subscriptions.
MOVIEPILOT_COMPAT_TEST_SUBSCRIPTION_SEARCH=true

# Fetch recent existing subscriptions and save them back unchanged.
MOVIEPILOT_COMPAT_TEST_SUBSCRIPTION_UPDATE=true

# Pause active subscriptions with state R, then restore them back to R.
# Already-paused subscriptions with state S are not resumed by this test.
MOVIEPILOT_COMPAT_TEST_SUBSCRIPTION_PAUSE_RESUME=true

# Reset recent existing subscriptions, then immediately trigger search on them.
MOVIEPILOT_COMPAT_TEST_SUBSCRIPTION_RESET_SEARCH=true
MOVIEPILOT_COMPAT_SIDE_EFFECT_SUBSCRIPTION_LIMIT=3

# Reorganize recent transfer-history records. Manual reorganize sends multiple
# recent records concurrently when the count allows it.
MOVIEPILOT_COMPAT_TEST_MANUAL_REORGANIZE=true
MOVIEPILOT_COMPAT_TEST_AI_REORGANIZE=true
MOVIEPILOT_COMPAT_REORGANIZE_HISTORY_LIMIT=2
MOVIEPILOT_COMPAT_REORGANIZE_CONCURRENT_COUNT=2
